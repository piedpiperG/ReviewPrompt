---
import CopyButton from './CopyButton.astro';
import type { PromptResource } from '../lib/catalog';
import { getLocaleFromPathname } from '../lib/localization';
import { t } from '../lib/ui';
import { pathWithBase } from '../lib/urls';

interface Props {
  resource: PromptResource & { statusLabel?: string };
}

const { resource } = Astro.props;
const locale = getLocaleFromPathname(Astro.url.pathname);
const labels = t(locale);
const statusLabel = 'statusLabel' in resource ? String(resource.statusLabel) : resource.status;
const primaryTags = [
  labels.prompt,
  statusLabel,
  ...resource.roles.slice(0, 2),
  ...resource.tasks.slice(0, 1),
];
const href = pathWithBase(resource.href);
---

<article class="rp-card">
  <div>
    <h3><a href={href}>{resource.title}</a></h3>
    <p>{resource.summary}</p>
  </div>

  <div class="rp-card__meta" aria-label={labels.resourceMetadata}>
    {primaryTags.map((tag) => <span class="rp-pill">{tag}</span>)}
  </div>

  <div class="rp-tags" aria-label={labels.tags}>
    {resource.tags.slice(0, 4).map((tag) => <span class="rp-pill">#{tag}</span>)}
  </div>

  <div class="rp-card__actions">
    <a class="rp-button secondary" href={href}>{labels.view}</a>
    <CopyButton
      text={resource.promptText}
      label={labels.copyPrompt}
      copiedLabel={labels.copied}
      failedLabel={labels.copyFailed}
    />
  </div>
</article>
