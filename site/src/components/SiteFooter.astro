---
import type { Locale } from '../lib/localization';
import { pathWithBase } from '../lib/urls';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isZh = locale === 'zh';
const year = new Date().getFullYear();
const links = isZh
  ? [
      { label: '提示词库', href: '/prompts/' },
      { label: '贡献提示词', href: '/contribute/' },
      { label: '关于', href: '/about/' },
    ]
  : [
      { label: 'Prompt Library', href: '/en/prompts/' },
      { label: 'Contribute', href: '/en/contribute/' },
      { label: 'About', href: '/en/about/' },
    ];
---

<footer class="site-footer">
  <div class="aw-container site-footer__inner">
    <div>
      <a class="site-footer__brand" href={pathWithBase(locale === 'zh' ? '/' : '/en/')}>ReviewPrompt</a>
      <p>
        {
          isZh
            ? '一个面向人工智能论文审稿的双语提示词库。'
            : 'A bilingual prompt library for AI paper review.'
        }
      </p>
    </div>
    <nav class="site-footer__links" aria-label={isZh ? '页脚导航' : 'Footer navigation'}>
      {links.map((item) => <a href={pathWithBase(item.href)}>{item.label}</a>)}
      <a href="https://github.com/piedpiperG/ReviewPrompt">GitHub</a>
    </nav>
  </div>
  <div class="aw-container site-footer__bottom">
    <span>© {year} ReviewPrompt</span>
    <span>{isZh ? 'Open prompts for AI-assisted review' : 'Open prompts for AI-assisted review'}</span>
  </div>
</footer>
