---
import ResourceCard from './ResourceCard.astro';
import { catalog } from '../lib/catalog';
import type { PromptResource } from '../lib/catalog';
import { getLocaleFromPathname, getLocalizedResource } from '../lib/localization';

interface Props {
  title?: string;
  description?: string;
  resources: PromptResource[];
}

const { title, description, resources } = Astro.props;
const locale = getLocaleFromPathname(Astro.url.pathname);
const resourcesByKey = new Map(
  catalog.prompts.map((resource) => [resource.slug, resource]),
);
const localizedResources = resources.map((resource) =>
  getLocalizedResource(resourcesByKey.get(resource.slug) ?? resource, locale),
);
---

<section class="rp-section">
  {title && <h2>{title}</h2>}
  {description && <p>{description}</p>}
  <div class="rp-grid">
    {localizedResources.map((resource) => <ResourceCard resource={resource} />)}
  </div>
</section>
