---
import { catalog } from '../lib/catalog';
import { getLocaleFromPathname, getLocalizedCatalog } from '../lib/localization';
import { t } from '../lib/ui';
import { pathWithBase } from '../lib/urls';

const locale = getLocaleFromPathname(Astro.url.pathname);
const labels = t(locale);
const localizedCatalog = getLocalizedCatalog(catalog, locale);
const choices =
  locale === 'zh'
    ? {
        roles: ['作者', '审稿人'],
        tasks: ['完整论文', 'Rebuttal'],
        domain: '人工智能',
      }
    : {
        roles: ['Author', 'Reviewer'],
        tasks: ['Full paper review', 'Rebuttal'],
        domain: 'Artificial Intelligence',
      };

const prompts = localizedCatalog.prompts.map((prompt) => ({
  ...prompt,
  href: pathWithBase(prompt.href),
}));
---

<section
  class="rp-section rp-recommender"
  data-task-recommender
  data-prompts={JSON.stringify(prompts)}
  data-initial-role={choices.roles[0]}
  data-initial-task={choices.tasks[0]}
  data-domain={choices.domain}
  data-ui-labels={JSON.stringify({
    prompt: labels.prompt,
    open: labels.open,
    copyPrompt: labels.copyPrompt,
    copied: labels.copied,
    copyFailed: labels.copyFailed,
    chosenPrompt: labels.chosenPrompt,
  })}
>
  <h2>{labels.recommenderTitle}</h2>
  <p>{labels.recommenderDescription}</p>

  <div class="rp-choice-grid" aria-label={labels.recommenderTitle}>
    <div class="rp-choice-group">
      <h3>{labels.role}</h3>
      <div class="rp-segmented" role="group" aria-label={labels.role}>
        {
          choices.roles.map((role, index) => (
            <button
              class="rp-segment"
              type="button"
              data-field="role"
              data-value={role}
              aria-pressed={index === 0 ? 'true' : 'false'}
            >
              {role}
            </button>
          ))
        }
      </div>
    </div>

    <div class="rp-choice-group">
      <h3>{labels.task}</h3>
      <div class="rp-segmented" role="group" aria-label={labels.task}>
        {
          choices.tasks.map((task, index) => (
            <button
              class="rp-segment"
              type="button"
              data-field="task"
              data-value={task}
              aria-pressed={index === 0 ? 'true' : 'false'}
            >
              {task}
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <p class="rp-domain-note">{labels.fixedDomain}</p>
  <div class="rp-recommender__result" data-result></div>
</section>

<script>
  interface ClientPrompt {
    slug: string;
    title: string;
    summary: string;
    href: string;
    roles: string[];
    tasks: string[];
    domains: string[];
    promptText: string;
  }

  const root = document.querySelector('[data-task-recommender]');

  if (root instanceof HTMLElement) {
    const prompts = JSON.parse(root.dataset.prompts ?? '[]') as ClientPrompt[];
    const result = root.querySelector('[data-result]');
    const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-field]'));
    const labels = JSON.parse(root.dataset.uiLabels ?? '{}') as {
      prompt: string;
      open: string;
      copyPrompt: string;
      copied: string;
      copyFailed: string;
      chosenPrompt: string;
    };
    const state = {
      role: root.dataset.initialRole ?? '',
      task: root.dataset.initialTask ?? '',
      domain: root.dataset.domain ?? '',
    };

    const normalize = (value: string) => value.trim().toLowerCase();
    const includes = (values: string[], target: string) =>
      values.some((value) => normalize(value) === normalize(target));
    const escapeHtml = (value: string) =>
      value
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');

    const findPrompt = () =>
      prompts.find(
        (prompt) =>
          includes(prompt.roles, state.role) &&
          includes(prompt.tasks, state.task) &&
          includes(prompt.domains, state.domain),
      ) ?? prompts[0];

    const render = () => {
      if (!(result instanceof HTMLElement)) return;

      buttons.forEach((button) => {
        const field = button.dataset.field as 'role' | 'task';
        button.setAttribute('aria-pressed', String(button.dataset.value === state[field]));
      });

      const prompt = findPrompt();
      if (!prompt) {
        result.innerHTML = '';
        return;
      }

      result.innerHTML = `
        <article class="rp-card rp-prompt-result">
          <span class="rp-pill">${escapeHtml(labels.chosenPrompt)}</span>
          <h3><a href="${escapeHtml(prompt.href)}">${escapeHtml(prompt.title)}</a></h3>
          <p>${escapeHtml(prompt.summary)}</p>
          <div class="rp-card__actions">
            <a class="rp-button secondary" href="${escapeHtml(prompt.href)}">${escapeHtml(labels.open)}</a>
            <button
              class="rp-copy-button"
              type="button"
              data-copy-text="${escapeHtml(prompt.promptText)}"
              data-copy-label="${escapeHtml(labels.copyPrompt)}"
              data-copied-label="${escapeHtml(labels.copied)}"
              data-failed-label="${escapeHtml(labels.copyFailed)}"
            >${escapeHtml(labels.copyPrompt)}</button>
          </div>
        </article>
      `;
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const field = button.dataset.field as 'role' | 'task';
        state[field] = button.dataset.value ?? state[field];
        render();
      });
    });

    render();
  }
</script>
