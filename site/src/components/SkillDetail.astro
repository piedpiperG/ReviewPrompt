---
import CopyButton from './CopyButton.astro';
import { catalog } from '../lib/catalog';
import { getLocaleFromPathname, getLocalizedCatalog } from '../lib/localization';
import { t } from '../lib/ui';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const locale = getLocaleFromPathname(Astro.url.pathname);
const labels = t(locale);
const skill = getLocalizedCatalog(catalog, locale).skills.find((item) => item.slug === slug);

if (!skill) {
  throw new Error(`Unknown skill slug: ${slug}`);
}
---

<div class="rp-detail">
  <section class="rp-detail__panel">
    <h2>{labels.skillOverview}</h2>
    <p>{skill.summary}</p>
    <div class="rp-card__meta">
      {[skill.status, skill.safetyLevel, ...skill.tools, ...skill.roles].map((item) => (
        <span class="rp-pill">{item}</span>
      ))}
    </div>
  </section>

  <section class="rp-detail__panel">
    <h2>{labels.installForCodex}</h2>
    <CopyButton
      text={skill.installCodex}
      label={labels.copyCodexInstall}
      copiedLabel={labels.copied}
      failedLabel={labels.copyFailed}
    />
    <pre class="rp-code-block"><code>{skill.installCodex}</code></pre>
  </section>

  <section class="rp-detail__panel">
    <h2>{labels.installForClaude}</h2>
    <CopyButton
      text={skill.installClaude}
      label={labels.copyClaudeInstall}
      copiedLabel={labels.copied}
      failedLabel={labels.copyFailed}
    />
    <pre class="rp-code-block"><code>{skill.installClaude}</code></pre>
  </section>

  <section class="rp-detail__panel">
    <h2>{labels.skillPreview}</h2>
    <p>{skill.skillPreview}</p>
  </section>

  <section class="rp-detail__panel">
    <h2>{labels.metadata}</h2>
    <ul>
      <li>{labels.version}: {skill.version}</li>
      <li>{labels.license}: {skill.license}</li>
      <li>{labels.scripts}: {skill.hasScripts ? labels.included : labels.noScripts}</li>
      <li>{labels.tasks}: {skill.tasks.join(', ')}</li>
      <li>{labels.domains}: {skill.domains.join(', ')}</li>
    </ul>
  </section>
</div>
