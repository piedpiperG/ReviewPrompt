---
import type { Locale } from '../lib/localization';
import { pathWithBase } from '../lib/urls';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isZh = locale === 'zh';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(base, '') || '/';
const languagePath = isZh
  ? `/en${currentPath === '/' ? '/' : currentPath}`
  : currentPath.replace(/^\/en(?=\/|$)/, '') || '/';

const nav = isZh
  ? [
      { label: '首页', href: '/' },
      { label: '提示词', href: '/prompts/' },
      { label: '贡献', href: '/contribute/' },
      { label: '关于', href: '/about/' },
    ]
  : [
      { label: 'Home', href: '/en/' },
      { label: 'Prompts', href: '/en/prompts/' },
      { label: 'Contribute', href: '/en/contribute/' },
      { label: 'About', href: '/en/about/' },
    ];

const githubLabel = isZh ? 'GitHub 仓库' : 'GitHub';
const languageLabel = isZh ? 'English' : '简体中文';
---

<header class="site-header">
  <div class="aw-container site-header__inner">
    <a class="site-logo" href={pathWithBase(isZh ? '/' : '/en/')} aria-label="ReviewPrompt">
      <span class="site-logo__mark">RP</span>
      <span>
        <strong>ReviewPrompt</strong>
        <small>AI Review Commons</small>
      </span>
    </a>

    <nav class="site-nav" aria-label={isZh ? '主导航' : 'Main navigation'}>
      {nav.map((item) => <a href={pathWithBase(item.href)}>{item.label}</a>)}
    </nav>

    <div class="site-header__actions">
      <a class="site-link" href={pathWithBase(languagePath)}>{languageLabel}</a>
      <a class="rp-button secondary" href="https://github.com/piedpiperG/ReviewPrompt">{githubLabel}</a>
    </div>
  </div>
</header>
