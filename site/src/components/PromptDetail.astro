---
import CopyButton from './CopyButton.astro';
import { catalog } from '../lib/catalog';
import { getLocaleFromPathname, getLocalizedCatalog } from '../lib/localization';
import { t } from '../lib/ui';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const locale = getLocaleFromPathname(Astro.url.pathname);
const labels = t(locale);
const prompt = getLocalizedCatalog(catalog, locale).prompts.find((item) => item.slug === slug);

if (!prompt) {
  throw new Error(`Unknown prompt slug: ${slug}`);
}
---

<div class="rp-detail">
  <section class="rp-detail__panel">
    <h2>{labels.overview}</h2>
    <p>{prompt.summary}</p>
    <div class="rp-card__meta">
      {[...prompt.roles, ...prompt.tasks, ...prompt.domains].map((item) => (
        <span class="rp-pill">{item}</span>
      ))}
    </div>
  </section>

  <section class="rp-detail__panel">
    <h2>{labels.useWhen}</h2>
    <ul>
      {prompt.roles.map((role) => <li>{role}</li>)}
      {prompt.tasks.map((task) => <li>{task}</li>)}
      {prompt.domains.map((domain) => <li>{domain}</li>)}
    </ul>
  </section>

  <section class="rp-detail__panel">
    <h2>{labels.prompt}</h2>
    <CopyButton
      text={prompt.promptText}
      label={labels.copyPrompt}
      copiedLabel={labels.promptCopied}
      failedLabel={labels.copyFailed}
    />
    <pre class="rp-code-block"><code>{prompt.promptText}</code></pre>
  </section>

  <section class="rp-detail__panel">
    <h2>{labels.inputFormat}</h2>
    <ul>{prompt.inputFormat.map((item) => <li>{item}</li>)}</ul>
  </section>

  <section class="rp-detail__panel">
    <h2>{labels.outputFormat}</h2>
    <ul>{prompt.outputFormat.map((item) => <li>{item}</li>)}</ul>
  </section>

  <section class="rp-detail__panel">
    <h2>{labels.knownLimits}</h2>
    <ul>{prompt.limitations.map((item) => <li>{item}</li>)}</ul>
  </section>

  <section class="rp-detail__panel">
    <h2>{labels.metadata}</h2>
    <ul>
      <li>{labels.source}: {prompt.source}</li>
      <li>{labels.license}: {prompt.license}</li>
      <li>{labels.contributor}: {prompt.contributor}</li>
      <li>{labels.models}: {prompt.modelCompatibility.join(', ')}</li>
    </ul>
  </section>
</div>
