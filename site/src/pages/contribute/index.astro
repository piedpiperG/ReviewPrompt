---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: '贡献提示词',
  description: '向 ReviewPrompt 提交人工智能论文审稿提示词。',
};
---

<Layout metadata={metadata} locale="zh">
  <HeroText
    tagline="Contribute"
    title="贡献提示词"
    subtitle="ReviewPrompt 当前优先接受作者侧论文质检、模拟审稿和 Rebuttal 相关提示词。"
  />

  <section class="mx-auto max-w-4xl px-4 py-10 md:px-6">
    <div class="prose prose-slate max-w-none rounded-3xl border border-gray-200 bg-white p-6 shadow-lg shadow-gray-200/50">
      <h2>可以提交什么</h2>
      <ul>
        <li>支持模拟审稿、逐项自查、Rebuttal 简报或相近作者工作流。</li>
        <li>是否适合拆成多个独立检查点。</li>
        <li>预期输入和输出。</li>
        <li>已知限制和安全风险。</li>
        <li>License、来源和贡献者署名。</li>
      </ul>

      <h2>提交路径</h2>
      <p>使用 GitHub Issue Form 提交提示词。</p>

      <h2>审核标准</h2>
      <ul>
        <li>任务和目标用户清晰。</li>
        <li>输出格式关注证据。</li>
        <li>不编造引用或会议政策。</li>
        <li>包含可用示例或模板。</li>
        <li>License 兼容。</li>
      </ul>
    </div>
  </section>
</Layout>
