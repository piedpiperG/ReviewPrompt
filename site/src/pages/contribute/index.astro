---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContributionWizard from '~/components/ContributionWizard.astro';

const metadata = {
  title: '贡献提示词',
  description: '向 ReviewPrompt 提交人工智能论文审稿提示词。',
};
---

<Layout metadata={metadata} locale="zh">
  <HeroText
    tagline="Contribute"
    title="贡献提示词"
    subtitle="ReviewPrompt 当前优先接受作者侧论文质检、模拟审稿和 Rebuttal 相关提示词。"
  />

  <ContributionWizard locale="zh" />
</Layout>
