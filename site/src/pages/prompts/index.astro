---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ResourceGrid from '~/components/ResourceGrid.astro';
import { catalog } from '~/lib/catalog';

const metadata = {
  title: '提示词库',
  description: '只保留完整论文和 Rebuttal 两个核心提示词。',
};
---

<Layout metadata={metadata} locale="zh">
  <HeroText
    tagline="Prompt Library"
    title="提示词库"
    subtitle="选择身份和任务后复制即可使用。当前领域固定为人工智能，后续再扩展更多任务。"
  />

  <ResourceGrid resources={catalog.prompts} />

  <section class="mx-auto max-w-5xl px-4 py-10 md:px-6">
    <div class="rounded-3xl border border-teal-100 bg-teal-50 p-6">
      <strong class="text-slate-950">当前范围</strong>
      <p class="mb-0 mt-2 text-muted">页面先服务两个高频动作：完整论文审稿、Rebuttal 回复。</p>
    </div>
  </section>
</Layout>
