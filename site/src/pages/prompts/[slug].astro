---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import PromptDetail from '~/components/PromptDetail.astro';
import { catalog } from '~/lib/catalog';
import { getLocalizedCatalog } from '~/lib/localization';

export function getStaticPaths() {
  return catalog.prompts.map((prompt) => ({ params: { slug: prompt.slug } }));
}

const { slug } = Astro.params;
const prompt = getLocalizedCatalog(catalog, 'zh').prompts.find((item) => item.slug === slug);

if (!prompt) {
  throw new Error(`Unknown prompt slug: ${slug}`);
}

const metadata = {
  title: prompt.title,
  description: prompt.summary,
};
---

<Layout metadata={metadata} locale="zh">
  <HeroText tagline="Prompt" title={prompt.title} subtitle={prompt.summary} />
  <section class="rp-detail-shell">
    <PromptDetail slug={prompt.slug} />
  </section>
</Layout>
