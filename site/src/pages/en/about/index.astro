---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'About ReviewPrompt',
  description: 'Product positioning and repository purpose.',
};
---

<Layout metadata={metadata} locale="en">
  <HeroText
    tagline="About"
    title="About ReviewPrompt"
    subtitle="ReviewPrompt currently focuses on author-side paper checks, reviewer simulation, and rebuttal briefing."
  />

  <section class="mx-auto max-w-4xl px-4 py-10 md:px-6">
    <div class="prose prose-slate max-w-none rounded-3xl border border-gray-200 bg-white p-6 shadow-lg shadow-gray-200/50">
      <p>The website is currently designed for authors who need to judge paper quality, find problems systematically, and prepare rebuttal material for advisors or coauthors.</p>
      <p>It starts with three local resources: reviewer imitation, a multi-pass author paper check workflow, and rebuttal briefing.</p>
      <p>The paper check workflow runs each checkpoint as a separate LLM review pass and includes copy-ready Codex / Claude Code agent instructions.</p>
    </div>
  </section>
</Layout>
