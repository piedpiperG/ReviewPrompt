---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'About ReviewPrompt',
  description: 'Product positioning and repository purpose.',
};
---

<Layout metadata={metadata} locale="en">
  <HeroText
    tagline="About"
    title="About ReviewPrompt"
    subtitle="ReviewPrompt is currently focused as an open prompt library for AI-assisted paper review."
  />

  <section class="mx-auto max-w-4xl px-4 py-10 md:px-6">
    <div class="prose prose-slate max-w-none rounded-3xl border border-gray-200 bg-white p-6 shadow-lg shadow-gray-200/50">
      <p>The website is designed around two users for now: authors and reviewers.</p>
      <p>It starts with two high-frequency prompts: full paper review and rebuttal response.</p>
      <p>More domains and more tasks can be added after the prompt experience is clear.</p>
    </div>
  </section>
</Layout>
