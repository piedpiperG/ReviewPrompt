---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ResourceGrid from '~/components/ResourceGrid.astro';
import { catalog } from '~/lib/catalog';

const metadata = {
  title: 'Prompt Library',
  description: 'Only the full paper and rebuttal prompts are shown for now.',
};
---

<Layout metadata={metadata} locale="en">
  <HeroText
    tagline="Prompt Library"
    title="Prompt Library"
    subtitle="Choose a role and task, then copy the prompt. The current domain is fixed to artificial intelligence."
  />

  <ResourceGrid resources={catalog.prompts} />

  <section class="mx-auto max-w-5xl px-4 py-10 md:px-6">
    <div class="rounded-3xl border border-teal-100 bg-teal-50 p-6">
      <strong class="text-slate-950">Current Scope</strong>
      <p class="mb-0 mt-2 text-muted">This page starts with two common actions: full paper review and rebuttal response.</p>
    </div>
  </section>
</Layout>
