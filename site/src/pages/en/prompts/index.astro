---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ResourceGrid from '~/components/ResourceGrid.astro';
import { catalog } from '~/lib/catalog';

const metadata = {
  title: 'Prompt Library',
  description: 'Author-side paper check, multi-pass review, and rebuttal briefing resources.',
};
---

<Layout metadata={metadata} locale="en">
  <HeroText
    tagline="Prompt Library"
    title="Prompt Library"
    subtitle="The library is currently organized around three source-backed resources: reviewer simulation, multi-pass checks, and rebuttal briefing."
  />

  <ResourceGrid resources={catalog.prompts} />

  <section class="mx-auto max-w-5xl px-4 py-10 md:px-6">
    <div class="rounded-3xl border border-teal-100 bg-teal-50 p-6">
      <strong class="text-slate-950">Current Scope</strong>
      <p class="mb-0 mt-2 text-muted">This page focuses on author-side work: judging paper quality, finding problems systematically, and preparing rebuttal material.</p>
    </div>
  </section>
</Layout>
