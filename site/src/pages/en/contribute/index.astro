---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContributionWizard from '~/components/ContributionWizard.astro';

const metadata = {
  title: 'Contribute',
  description: 'Submit AI paper review prompts to ReviewPrompt.',
};
---

<Layout metadata={metadata} locale="en">
  <HeroText
    tagline="Contribute"
    title="Contribute"
    subtitle="ReviewPrompt currently prioritizes author-side paper checks, reviewer simulation, and rebuttal prompts."
  />

  <ContributionWizard locale="en" />
</Layout>
