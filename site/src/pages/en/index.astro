---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import AgentInstallPanel from '~/components/AgentInstallPanel.astro';
import PromptPackageGrid from '~/components/PromptPackageGrid.astro';
import ResourceGrid from '~/components/ResourceGrid.astro';
import ScenarioEntryGrid from '~/components/ScenarioEntryGrid.astro';
import { catalog, getFeaturedResources } from '~/lib/catalog';
import { getLocalizedCatalog } from '~/lib/localization';
import { getPermalink } from '~/utils/permalinks';

const featured = getFeaturedResources(catalog);
const localizedCatalog = getLocalizedCatalog(catalog, 'en');
const agentPackage = localizedCatalog.promptPackages.find((item) => item.slug === 'agent-skill-install-pack');
const metadata = {
  title: 'AI Review Commons',
  description: 'Prompt packages and installable agent skills for AI paper review.',
};
---

<Layout metadata={metadata} locale="en">
  <Hero
    tagline="AI Review Commons"
    actions={[
      { variant: 'primary', text: 'Start by Scenario', href: '#scenario-entry', icon: 'tabler:route' },
      { text: 'Install Agent Skill', href: '#agent-skill-install-pack' },
    ]}
  >
    <Fragment slot="title">
      Installable prompt packages for <span class="text-primary">AI paper review</span>
    </Fragment>

    <Fragment slot="subtitle">
      Choose a package for submission readiness, reviewer simulation, or rebuttal sprint. Then hand one ReviewPrompt URL
      to Codex / Claude Code so review skills can live inside the paper workspace.
    </Fragment>

    <Fragment slot="image">
      <div class="mx-auto max-w-4xl rounded-3xl border border-teal-100 bg-white p-5 text-left shadow-2xl shadow-slate-200/80">
        <div class="mb-5 flex gap-2">
          <span class="h-3 w-3 rounded-full bg-rose-400"></span>
          <span class="h-3 w-3 rounded-full bg-amber-400"></span>
          <span class="h-3 w-3 rounded-full bg-emerald-400"></span>
        </div>
        <div class="grid gap-5 md:grid-cols-[0.8fr_1.2fr]">
          <div class="rounded-2xl bg-slate-950 p-5 text-teal-50">
            <p class="mb-3 text-sm font-bold uppercase text-teal-300">ReviewPrompt Packs</p>
            <h2 class="m-0 text-3xl font-bold leading-tight text-white">4 paper-stage entries</h2>
            <div class="mt-5 flex flex-wrap gap-2 text-sm">
              <span class="rounded-full bg-white/10 px-3 py-1">Submission readiness</span>
              <span class="rounded-full bg-white/10 px-3 py-1">Review pressure test</span>
              <span class="rounded-full bg-white/10 px-3 py-1">Rebuttal sprint</span>
              <span class="rounded-full bg-white/10 px-3 py-1">Agent skill install</span>
            </div>
          </div>
          <div class="space-y-3 rounded-2xl bg-teal-50 p-5">
            <div class="h-4 w-4/5 rounded-full bg-teal-200"></div>
            <div class="h-4 w-3/5 rounded-full bg-teal-100"></div>
            <div class="mt-6 rounded-xl border border-teal-200 bg-white p-4">
              <p class="m-0 text-sm font-semibold text-slate-500">One line for your agent</p>
              <p class="m-0 mt-1 text-xl font-bold text-slate-950">Install ReviewPrompt paper-review skills</p>
            </div>
          </div>
        </div>
      </div>
    </Fragment>
  </Hero>

  <div id="scenario-entry">
    <ScenarioEntryGrid
      title="Where are you in the paper cycle?"
      description="Start with the situation, not the prompt. Each entry points to a package of prompts and agent workflow instructions."
      scenarios={localizedCatalog.scenarios}
    />
  </div>

  <PromptPackageGrid
    title="Prompt Packages"
    description="Single prompts, independent review passes, and agent instructions are bundled into executable paper-review paths."
    packages={localizedCatalog.promptPackages}
    openLabel="Open Prompt"
    includedLabel="Included"
    outcomeLabel="Outcome"
  />

  {agentPackage && (
    <AgentInstallPanel
      title="Install ReviewPrompt into Codex / Claude Code"
      subtitle="This first version provides a copy-ready install instruction and GitHub Skill URLs. Give it to the agent so later paper reviews can run without manual prompt copying."
      noCopyLabel="No manual prompt copying"
      promptPackage={agentPackage}
      copyLabel="Copy Install Instruction"
      copiedLabel="Copied"
      failedLabel="Copy failed"
    />
  )}

  <ResourceGrid
    title="Underlying Prompt Resources"
    description="Packages still expose the source prompts so users can inspect or copy individual pieces when needed."
    resources={featured.prompts}
  />

  <Features
    tagline="Principles"
    title="Organized around real author work"
    columns={3}
    items={[
      {
        title: 'Scenario first',
        description: 'Users begin from submission, reviewer simulation, rebuttal, or agent installation instead of browsing isolated prompts.',
        icon: 'tabler:route',
      },
      {
        title: 'Prompts become paths',
        description: 'Packages connect single prompts, checkpoint passes, and workflow instructions into a clearer review route.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Installable by design',
        description: 'The main promise is to hand ReviewPrompt to Codex / Claude Code so paper-review skills enter the workspace.',
        icon: 'tabler:terminal-2',
      },
    ]}
  />

  <CallToAction
    title="Next, turn contributions into packages"
    subtitle="Community prompts can enter review, then graduate into submission, rebuttal, or agent-skill packages."
    actions={[{ variant: 'primary', text: 'Submit a Prompt', href: getPermalink('/en/contribute'), icon: 'tabler:arrow-right' }]}
  />
</Layout>
