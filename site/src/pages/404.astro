---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import { getPermalink } from '~/utils/permalinks';
---

<Layout metadata={{ title: 'Page Not Found', description: 'The requested page does not exist.' }} locale="zh">
  <HeroText
    tagline="404"
    title="页面不存在"
    subtitle="这个页面可能已经被移除。当前网站只保留提示词相关页面。"
    callToAction={{ variant: 'primary', text: '返回首页', href: getPermalink('/') }}
    callToAction2={{ text: '查看提示词', href: getPermalink('/prompts') }}
  />
</Layout>
