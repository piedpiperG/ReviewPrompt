---
import ResourceGrid from '../components/ResourceGrid.astro';
import TaskRecommender from '../components/TaskRecommender.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { catalog, getFeaturedResources } from '../lib/catalog';
import { pathWithBase } from '../lib/urls';

const featured = getFeaturedResources(catalog);
---

<SiteLayout title="AI Review Commons" description="面向人工智能论文审稿的双语提示词库。" locale="zh">
  <section class="aw-hero">
    <div class="aw-hero__bg" aria-hidden="true"></div>
    <div class="aw-container aw-hero__grid">
      <div class="aw-hero__copy">
        <p class="aw-eyebrow">AI Review Commons</p>
        <h1>把论文审稿提示词做成一个清晰好用的工具。</h1>
        <p class="aw-hero__lead">
          当前只服务人工智能论文场景。选择作者或审稿人，再选择完整论文或 Rebuttal，直接复制可用提示词。
        </p>
        <div class="aw-actions">
          <a class="rp-button" href={pathWithBase('/prompts/')}>选择提示词</a>
          <a class="rp-button secondary" href={pathWithBase('/contribute/')}>提交提示词</a>
        </div>
      </div>
      <div class="aw-hero__panel" aria-label="ReviewPrompt 当前范围">
        <div class="aw-prompt-window">
          <div class="aw-window-bar"><span></span><span></span><span></span></div>
          <p class="aw-window-kicker">Prompt Scope</p>
          <h2>2 种身份 × 2 个任务</h2>
          <div class="aw-token-row">
            <span>作者</span>
            <span>审稿人</span>
            <span>完整论文</span>
            <span>Rebuttal</span>
            <span>人工智能</span>
          </div>
          <div class="aw-window-line"></div>
          <div class="aw-window-line short"></div>
          <div class="aw-window-line muted"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="aw-container aw-band">
    <div class="aw-section-heading">
      <p class="aw-eyebrow">快速选择</p>
      <h2>两步找到可复制的提示词</h2>
    </div>
    <TaskRecommender />
  </section>

  <ResourceGrid
    title="当前只保留两个提示词"
    description="完整论文审稿和 Rebuttal 是第一版核心任务。"
    resources={featured.prompts}
  />

  <section class="aw-container aw-section">
    <div class="aw-section-heading">
      <p class="aw-eyebrow">原则</p>
      <h2>少功能，先把提示词体验做好</h2>
    </div>
    <div class="aw-feature-grid">
      <article class="aw-feature-card">
        <span>01</span>
        <h3>只保留核心路径</h3>
        <p>首页只留下身份、任务和复制提示词，避免多余模块分散注意力。</p>
      </article>
      <article class="aw-feature-card">
        <span>02</span>
        <h3>证据优先</h3>
        <p>提示词要求使用用户提供的论文内容，避免编造引用、实验和会议规则。</p>
      </article>
      <article class="aw-feature-card">
        <span>03</span>
        <h3>中英双语</h3>
        <p>中文是默认版本，英文版本保留同样的信息架构。</p>
      </article>
    </div>
  </section>
</SiteLayout>
