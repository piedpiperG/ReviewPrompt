---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import ResourceGrid from '~/components/ResourceGrid.astro';
import TaskRecommender from '~/components/TaskRecommender.astro';
import { catalog, getFeaturedResources } from '~/lib/catalog';
import { getPermalink } from '~/utils/permalinks';

const featured = getFeaturedResources(catalog);
const metadata = {
  title: 'AI Review Commons',
  description: '面向作者的论文质检、模拟审稿和 Rebuttal 简报提示词库。',
};
---

<Layout metadata={metadata} locale="zh">
  <Hero
    tagline="AI Review Commons"
    actions={[
      { variant: 'primary', text: '选择提示词', href: getPermalink('/prompts'), icon: 'tabler:copy' },
      { text: '提交提示词', href: getPermalink('/contribute') },
    ]}
  >
    <Fragment slot="title">
      把论文审稿提示词做成
      <span class="text-primary">清晰好用</span> 的工具
    </Fragment>

    <Fragment slot="subtitle">
      当前围绕三个真实资源重排：模拟审稿人评估论文质量、逐项多轮自查论文问题、整理 Rebuttal 简报。
    </Fragment>

    <Fragment slot="image">
      <div class="mx-auto max-w-4xl rounded-3xl border border-teal-100 bg-white p-5 text-left shadow-2xl shadow-slate-200/80">
        <div class="mb-5 flex gap-2">
          <span class="h-3 w-3 rounded-full bg-rose-400"></span>
          <span class="h-3 w-3 rounded-full bg-amber-400"></span>
          <span class="h-3 w-3 rounded-full bg-emerald-400"></span>
        </div>
        <div class="grid gap-5 md:grid-cols-[0.8fr_1.2fr]">
          <div class="rounded-2xl bg-slate-950 p-5 text-teal-50">
            <p class="mb-3 text-sm font-bold uppercase text-teal-300">Prompt Scope</p>
            <h2 class="m-0 text-3xl font-bold leading-tight text-white">3 个作者工作台</h2>
            <div class="mt-5 flex flex-wrap gap-2 text-sm">
              <span class="rounded-full bg-white/10 px-3 py-1">模拟审稿</span>
              <span class="rounded-full bg-white/10 px-3 py-1">逐项质检</span>
              <span class="rounded-full bg-white/10 px-3 py-1">Rebuttal</span>
              <span class="rounded-full bg-white/10 px-3 py-1">Skill 工作流</span>
            </div>
          </div>
          <div class="space-y-3 rounded-2xl bg-teal-50 p-5">
            <div class="h-4 w-4/5 rounded-full bg-teal-200"></div>
            <div class="h-4 w-3/5 rounded-full bg-teal-100"></div>
            <div class="mt-6 rounded-xl border border-teal-200 bg-white p-4">
              <p class="m-0 text-sm font-semibold text-slate-500">推荐路径</p>
              <p class="m-0 mt-1 text-xl font-bold text-slate-950">先跑逐项论文质检</p>
            </div>
          </div>
        </div>
      </div>
    </Fragment>
  </Hero>

  <section class="rp-shell">
    <div class="mx-auto max-w-5xl px-4 md:px-6">
      <div class="mb-8 text-center">
        <p class="text-base font-bold uppercase text-secondary">快速选择</p>
        <h2 class="font-heading text-4xl font-bold tracking-tight text-slate-950 md:text-5xl">按当前任务选择资源</h2>
      </div>
      <TaskRecommender />
    </div>
  </section>

  <ResourceGrid
    title="当前三个可用资源"
    description="一个模拟审稿人 Prompt，一个多轮作者自查工作流，一个 Rebuttal 简报 Prompt。"
    resources={featured.prompts}
  />

  <Features
    tagline="原则"
    title="按真实使用场景组织"
    columns={3}
    items={[
      {
        title: '作者视角优先',
        description: '当前资源都服务作者：先判断论文质量，再逐项找问题，最后组织 Rebuttal 沟通材料。',
        icon: 'tabler:route',
      },
      {
        title: '逐项独立检查',
        description: '论文自查工作流把 7 个小点拆开跑，减少一次性总评带来的泛泛反馈。',
        icon: 'tabler:shield-check',
      },
      {
        title: '可插入 Agent',
        description: '工作流详情页提供 Codex / Claude Code 可复制指令，便于在论文项目里多轮 review。',
        icon: 'tabler:terminal-2',
      },
    ]}
  />

  <CallToAction
    title="先把作者自查链路打磨清楚"
    subtitle="从模拟审稿、逐项质检到 rebuttal 简报，先覆盖投稿前后最常见的三类动作。"
    actions={[{ variant: 'primary', text: '查看提示词库', href: getPermalink('/prompts'), icon: 'tabler:arrow-right' }]}
  />
</Layout>
