---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: '关于 ReviewPrompt',
  description: '产品定位和仓库目标。',
};
---

<Layout metadata={metadata} locale="zh">
  <HeroText
    tagline="About"
    title="关于 ReviewPrompt"
    subtitle="ReviewPrompt 现在先聚焦作者侧论文质检、模拟审稿和 Rebuttal 沟通材料。"
  />

  <section class="mx-auto max-w-4xl px-4 py-10 md:px-6">
    <div class="prose prose-slate max-w-none rounded-3xl border border-gray-200 bg-white p-6 shadow-lg shadow-gray-200/50">
      <p>当前网页优先服务作者：投稿前判断论文质量、系统性检查问题、以及 rebuttal 阶段给老师和 coauthor 准备简报。</p>
      <p>它先提供三个本地资源改造出的条目：模拟审稿人检查、作者逐项论文质检工作流、Rebuttal 简报整理。</p>
      <p>逐项论文质检工作流会把每个小点单独做一次 LLM review，并提供可复制到 Codex / Claude Code 的代理工作流指令。</p>
    </div>
  </section>
</Layout>
