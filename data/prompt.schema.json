{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reviewprompt.dev/schemas/prompt.schema.json",
  "title": "ReviewPrompt Prompt",
  "type": "object",
  "required": ["slug", "title", "summary", "roles", "tasks", "domains", "status", "promptText"],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 3 },
    "summary": { "type": "string", "minLength": 20 },
    "roles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "tasks": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "domains": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "status": { "enum": ["curated", "tested", "experimental", "deprecated"] },
    "promptText": { "type": "string", "minLength": 40 }
  },
  "additionalProperties": true
}
